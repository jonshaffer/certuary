{
  "name": "certuary",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "generate": "pnpm --filter @certuary/data generate",
    "dev": "pnpm generate && pnpm --filter @certuary/web dev",
    "build": "pnpm generate && pnpm --filter @certuary/web build && pnpm --filter @certuary/data generate:api -- --out-dir ../../apps/web/dist/api",
    "typecheck": "pnpm generate && pnpm -r typecheck",
    "test": "pnpm generate && pnpm --filter @certuary/web test",
    "preview": "pnpm --filter @certuary/web preview"
  }
}
